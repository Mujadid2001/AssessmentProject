{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "builds": [
    {
      "src": "backend/wsgi_vercel.py",
      "use": "@vercel/python@latest",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11",
        "requirements": "requirements.txt"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/wsgi_vercel.application"
    },
    {
      "src": "/admin/(.*)",
      "dest": "backend/wsgi_vercel.application"
    },
    {
      "src": "/assets/(.*)",
      "continue": true
    },
    {
      "src": "/favicon.ico",
      "dest": "frontend/dist/favicon.ico"
    },
    {
      "src": "/(.*\\..*)",
      "dest": "frontend/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/index.html"
    }
  ],
  "env": {
    "DEBUG": "False",
    "PYTHON_VERSION": "3.11"
  },
  "regions": ["iad1"]
}

