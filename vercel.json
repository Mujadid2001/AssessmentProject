{
  "version": 2,
  "framework": "vite",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "public": "frontend/dist",
  "builds": [
    {
      "src": "backend/wsgi_vercel.py",
      "use": "@vercel/python@latest",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11",
        "requirements": "requirements.txt"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/wsgi_vercel.application"
    },
    {
      "src": "/assets/(.*)",
      "headers": {"cache-control": "public, max-age=31536000, immutable"},
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\..*)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "DEBUG": "False",
    "PYTHON_VERSION": "3.11"
  },
  "regions": ["iad1"]
}

